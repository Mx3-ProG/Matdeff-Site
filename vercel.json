{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/ads.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/signup",
      "destination": "/signup.html"
    }
  ],
  "redirects": [
    {
      "source": "/landing-page",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/landing-page.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/Pub",
      "destination": "/security_accompt",
      "permanent": true
    },
    {
      "source": "/Pub.html",
      "destination": "/security_accompt",
      "permanent": true
    },
    {
      "source": "/pub",
      "destination": "/security_accompt",
      "permanent": true
    },
    {
      "source": "/pub.html",
      "destination": "/security_accompt",
      "permanent": true
    },
    {
      "source": "/dashboard.html",
      "destination": "/dashboard",
      "permanent": true
    },
    {
      "source": "/signup.html",
      "destination": "/signup",
      "permanent": true
    }
  ]
}
