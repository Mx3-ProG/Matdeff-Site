{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/signup",
      "destination": "/signup.html"
    }
  ],
  "redirects": [
    {
      "source": "/landing-page",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/landing-page.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/dashboard.html",
      "destination": "/dashboard",
      "permanent": true
    },
    {
      "source": "/signup.html",
      "destination": "/signup",
      "permanent": true
    }
  ]
}
